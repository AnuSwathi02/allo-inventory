# .env.example — copy to .env.local and fill in your values

# Postgres connection string (from Supabase / Neon / Railway)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://..."

# Redis connection string (from Upstash)
# Format: redis://default:PASSWORD@HOST:PORT
REDIS_URL="redis://..."

# Secret for protecting the cron endpoint — generate with: openssl rand -hex 32
CRON_SECRET="your-random-secret-here"
